{
  "name": "react-comments-mui",
  "homepage": "https://winglunlam.github.io/react-comments-mui",
  "version": "0.1.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winglunlam/react-comments-mui"
  },
  "description": "A YouTube-style comment section library for React using MUI",
  "dependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@mui/icons-material": "^6.0.0 || ^7.0.0",
    "@mui/material": "^6.0.0 || ^7.0.0",
    "@mui/system": "^7.2.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "emoji-picker-react": "^4.0.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "webpack serve --open --hot --mode development --static ./example",
    "build": "webpack --config webpack.config.prod.js",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "npm run build && npm run build:types",
    "predeploy": "cd example && npm install && npm run build",
    "deploy": "gh-pages -d dist",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@mui/icons-material": "^6.0.0 || ^7.0.0",
    "@mui/material": "^6.0.0 || ^7.0.0",
    "emoji-picker-react": "^4.0.0",
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "html-webpack-plugin": "^5.6.3",
    "ts-loader": "^9.5.2",
    "typescript": "^4.9.5",
    "webpack": "^5.100.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "keywords": [
    "react",
    "comment-section",
    "youtube",
    "mui",
    "material-ui"
  ],
  "author": "Alan Lam",
  "license": "MIT"
}
